@model IEnumerable<GearGauge.Models.GearInventory>

<h1>Your Gear Inventory</h1>

<p>
    <a asp-controller="GearInventory" asp-action="Add" class="btn btn-primary">Add Gear Inventory</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Market Value</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.Description</td>
            <td>@item.MarketValue</td>
            <td>
                <a asp-controller="GearInventory" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-primary">Details</a>
                <a asp-controller="GearInventory" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Edit</a>
                <a asp-controller="GearInventory" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
